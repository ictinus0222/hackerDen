# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/hackathon-management

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Redis Configuration (optional, for production caching and sessions)
REDIS_URL=redis://localhost:6379

# Production Database Configuration (MongoDB Atlas)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hackathon-management?retryWrites=true&w=majority

# Production Redis Configuration (Redis Cloud)
# REDIS_URL=redis://username:password@redis-host:port

# Production Frontend URL
# FRONTEND_URL=https://your-frontend-domain.com

# Security Configuration (Production)
# SESSION_SECRET=your-session-secret-key-for-production
# ENCRYPTION_KEY=your-32-character-encryption-key

# Monitoring and Logging (Optional)
# LOG_LEVEL=info
# SENTRY_DSN=your-sentry-dsn-for-error-tracking