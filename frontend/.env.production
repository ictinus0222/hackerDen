# Production Frontend Configuration
NODE_ENV=production

# API Configuration - Update with your deployed backend URL
VITE_API_URL=https://hackathon-management-backend.railway.app
VITE_SOCKET_URL=https://hackathon-management-backend.railway.app

# Feature flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true

# Build configuration
VITE_BUILD_VERSION=1.0.0