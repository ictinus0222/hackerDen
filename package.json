{
  "name": "hackathon-management-tool",
  "version": "1.0.0",
  "description": "hackerDen - Hackathon Management Tool",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "build:production": "cross-env NODE_ENV=production npm run build",
    "start": "cd backend && npm run start",
    "start:production": "cross-env NODE_ENV=production npm run start",
    "test": "concurrently \"npm run test:frontend\" \"npm run test:backend\"",
    "test:frontend": "cd frontend && npm run test:run",
    "test:backend": "cd backend && npm run test:run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:e2e",
    "clean": "rm -rf frontend/dist backend/dist",
    "clean:install": "npm run clean && rm -rf node_modules frontend/node_modules backend/node_modules && npm run install:all",
    "preview": "cd frontend && npm run preview",
    "deploy:build": "npm run clean && npm run install:all && npm run build:production",
    "deploy:production": "./scripts/deploy.sh",
    "health-check": "node scripts/health-check.js",
    "health-check:local": "curl -f http://localhost:3000/health || exit 1",
    "test:production": "node scripts/test-production.js",
    "monitor:production": "node scripts/health-check.js && node scripts/test-production.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.0.0"
  },
  "keywords": [
    "hackathon",
    "management",
    "collaboration",
    "react",
    "express"
  ],
  "author": "",
  "license": "MIT"
}
